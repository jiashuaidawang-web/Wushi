# =========================================================================
# 1. 后端核心过滤 (Java / Spring Boot 3 / Maven)
# =========================================================================
target/
!.mvn/wrapper/maven-wrapper.jar
build/
.gradle/

# =========================================================================
# 2. 前端核心过滤 (Vue 3 / Vite / TypeScript / Node)
# =========================================================================
# 绝对不能提交的依赖包目录
node_modules/
.pnpm-store/
.yarn/

# Vite 及 TS 的本地编译与运行缓存
.vite/
.nuxt/
.vuepress/dist
.serverless/
.tsbuildinfo

# 前端各种打包工具的本地日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 代码检查工具的缓存
.eslintcache
.stylelintcache

# =========================================================================
# 3. 前端编译产物过滤
# =========================================================================
# Vite 默认的打包输出目录
dist/
dist-ssr/
/out-tsc/

# 💡 特别注意：
# 如果你的 Vite 配置中，打包后的静态资源直接直接输出到了后端的 static 目录：
#（例如：build.outDir = '../src/main/resources/static'）
# 并且你不希望把每次编译生成的混淆 JS/CSS 提交进 Git，可以取消下面两行的注释：
# src/main/resources/static/assets/
# src/main/resources/static/index.html

# =========================================================================
# 4. 全栈通用：本地敏感环境配置 (防爬虫代理、密钥、数据库密码泄露)
# =========================================================================
# 前端 Vite 使用的本地环境变量
.env.local
.env.*.local

# 后端 Spring Boot 使用的本地配置文件
application-local.properties
application-local.yml
application-local.yaml

# =========================================================================
# 5. IDE 配置文件与操作系统临时文件
# =========================================================================
.idea/
*.iml
*.iws
*.ipr
.vscode/
[Dd]s.[Ss]tore
Thumbs.db

# =========================================================================
# 6. 系统日志与临时文件 (包含你配置的本地 Log4j2 全异步日志输出)
# =========================================================================
logs/
*.log
*.log.gz
/tmp/
